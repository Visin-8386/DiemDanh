# ─────────────────────────────────────────
# Database – PostgreSQL
# ─────────────────────────────────────────
POSTGRES_DB=diemdanh
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
DATABASE_URL=postgresql://your_db_user:your_db_password@postgres:5432/diemdanh

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:your_redis_password@redis:6379

# ─────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-string
JWT_REFRESH_SECRET=change-this-to-another-random-secret-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────
# MinIO – Object Storage
# ─────────────────────────────────────────
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=diemdanh-photos
MINIO_USE_SSL=false

# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
NODE_ENV=development
APP_PORT=4000
FRONTEND_URL=http://localhost

# ─────────────────────────────────────────
# AI Service
# ─────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:5000
FACE_CONFIDENCE_THRESHOLD=0.6

# ─────────────────────────────────────────
# Default Admin Account
# ─────────────────────────────────────────
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=YourAdminPassword
